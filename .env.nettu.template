# EPW Nettu Scheduler — Environment Variables
# Gary (EPW CTO) is responsible for populating .env.nettu from the vault.
# Vault path: secret/nettu-scheduler
# Required fields: pg_password, account_secret
#
# To generate .env.nettu from vault:
#   node scripts/gary-vault.js read secret/nettu-scheduler
#
DATABASE_URL=postgresql://postgres:REPLACE_WITH_PG_PASSWORD@host.docker.internal:5432/nettuscheduler
PORT=5000
CREATE_ACCOUNT_SECRET_CODE=REPLACE_WITH_ACCOUNT_SECRET
